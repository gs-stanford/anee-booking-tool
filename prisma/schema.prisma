generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum InstrumentStatus {
  AVAILABLE
  UNAVAILABLE
}

enum SafetyMaterialFlow {
  INCOMING
  OUTGOING
}

enum RiskAssessmentLevel {
  LOW
  MEDIUM
  HIGH
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  passwordHash       String
  role               Role               @default(MEMBER)
  ownedInstruments   Instrument[]       @relation("InstrumentOwner")
  reservations       Reservation[]
  maintenanceEntries MaintenanceEntry[] @relation("MaintenancePerformedBy")
  safetyMaterialLogs SafetyMaterialLog[] @relation("SafetyMaterialLoggedBy")
  riskAssessments    RiskAssessment[]    @relation("RiskAssessmentsCreated")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Instrument {
  id                 String             @id @default(cuid())
  name               String             @unique
  location           String
  description        String
  status             InstrumentStatus   @default(AVAILABLE)
  statusNote         String?
  unavailableFrom    DateTime?
  unavailableUntil   DateTime?
  unavailableReminderSentAt DateTime?
  ownerId            String?
  owner              User?              @relation("InstrumentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  manuals            Manual[]
  maintenanceEntries MaintenanceEntry[]
  reservations       Reservation[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([ownerId])
}

model Manual {
  id           String     @id @default(cuid())
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  originalName String
  storedName   String
  mimeType     String
  filePath     String
  uploadedAt   DateTime   @default(now())
}

model MaintenanceEntry {
  id            String     @id @default(cuid())
  instrumentId  String
  instrument    Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  performedById String?
  performedBy   User?      @relation("MaintenancePerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  performedAt   DateTime
  summary       String
  status        String
  notes         String?
  createdAt     DateTime   @default(now())
}

model Reservation {
  id           String     @id @default(cuid())
  instrumentId String
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  startAt      DateTime
  endAt        DateTime
  purpose      String?
  createdAt    DateTime   @default(now())

  @@index([instrumentId, startAt, endAt])
}

model SafetyMaterialLog {
  id            String             @id @default(cuid())
  flow          SafetyMaterialFlow
  title         String
  vendor        String
  category      String
  initialAmount String
  loggedAt      DateTime
  loggedById    String?
  loggedBy      User?              @relation("SafetyMaterialLoggedBy", fields: [loggedById], references: [id], onDelete: SetNull)
  createdAt     DateTime           @default(now())

  @@index([flow, loggedAt])
  @@index([title])
  @@index([category])
}

model RiskAssessment {
  id                      String              @id @default(cuid())
  experimentName          String
  location                String
  startDate               DateTime
  endDate                 DateTime
  procedureDescription    String
  riskLevel               RiskAssessmentLevel
  hazardsJson             String
  ppe                     String
  emergencyInstructions   String
  specialMonitoring       String?
  furtherControlMeasures  String?
  specialistApproval      String?
  outOfHoursLoneWorking   String?
  assessorName            String
  assessorEmail           String
  supervisorName          String
  additionalUsers         String?
  createdById             String?
  createdBy               User?               @relation("RiskAssessmentsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([createdAt])
  @@index([experimentName])
  @@index([riskLevel])
}
